{
  "name": "site-fetchkit",
  "version": "0.1.4",
  "type": "module",
  "description": "Site fetching runtime for agent skills, with Playwright login state and browser/request helpers.",
  "license": "MIT",
  "keywords": [
    "agent",
    "cli",
    "playwright",
    "web-fetching",
    "authenticated-fetch",
    "site-skills",
    "browser-automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/streaker303/site-fetchkit.git"
  },
  "homepage": "https://github.com/streaker303/site-fetchkit#readme",
  "bin": {
    "site-fetchkit": "./bin/site-fetchkit.mjs"
  },
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs"
  },
  "files": [
    "bin",
    "src",
    "skills",
    "README.md"
  ],
  "scripts": {
    "test": "node --test",
    "check": "find bin src -name '*.mjs' -print0 | xargs -0 -n 1 node --check"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "playwright": "^1.50.0"
  }
}
